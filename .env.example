# PostgreSQL connection string used by Prisma.
# Example: postgresql://postgres:postgres@localhost:5432/virtual_goods_shop?schema=public
DATABASE_URL=

# Legacy admin placeholders kept for compatibility with earlier phases.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Back-office login. Replace all sample values before deployment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-long-random-secret

# Public site config. NEXT_PUBLIC_SITE_URL must be the full deployed origin
# because Stripe Checkout success_url and cancel_url are built from it.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Virtual Goods Shop"
DEFAULT_SEO_TITLE="Virtual Goods Shop"
DEFAULT_SEO_DESCRIPTION="支持 Stripe Checkout 在线支付、Stripe webhook 确认付款和后台人工确认发货的虚拟商品商城"
FOOTER_DESCRIPTION="支持 Stripe Checkout 在线支付、Stripe webhook 确认付款和后台人工确认发货的虚拟商品商城"

# Customer service contacts displayed in the storefront.
MANUAL_PAYMENT_NOTICE=
CUSTOMER_SERVICE_TELEGRAM=
CUSTOMER_SERVICE_EMAIL=
AFTER_SALES_NOTICE=
PRODUCT_DEFAULT_NOTICE=
PRODUCT_DEFAULT_DELIVERY=

# Stripe Checkout payment gateway.
PAYMENT_PROVIDER=stripe
PAYMENT_CURRENCY=cny
NEXT_PUBLIC_PAYMENT_GATEWAY_NAME="Stripe Checkout"
STRIPE_SECRET_KEY=

# Stripe webhook signing secret for /api/payments/stripe/webhook.
# Use the endpoint secret from Stripe Dashboard or `stripe listen`.
STRIPE_WEBHOOK_SECRET=

# Aliyun OSS product image uploads. Use ALIYUN_OSS_PUBLIC_BASE_URL as the
# public image origin, preferably a CDN domain such as https://img.example.com.
ALIYUN_OSS_REGION=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_PUBLIC_BASE_URL=
